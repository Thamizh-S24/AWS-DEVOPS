pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '0'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Stop Existing Containers') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose down || true'
                }
            }
        }

        stage('Build Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose build'
                }
            }
        }

        stage('Start Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose up -d'
                }
            }
        }

        stage('Wait for Services') {
            steps {
                sh '''
                
                echo "Waiting for service to be ready..."

                for i in $(seq 1 20); do
                  if docker exec hms_auth python -c "
         import requests
         r = requests.get('http://localhost:8000/docs')
         exit(0 if r.status_code == 200 else 1)
         " >/dev/null 2>&1; then
                    echo "Service is UP ✅"
                    exit 0
                  fi

                  echo "Still Waiting...($i)"
                  sleep 6
                done

                echo "Service failed to start ❌"
                echo "====== AUTH SERVICE LOGS ======"
                docker logs hms_auth
                exit 1
                '
                '''
            }
        }

        stage('Install Test Dependencies') {
            steps {
                sh '''
                docker exec hms_auth pip install -r /app/requirements.txt
                docker exec hms_auth pip install -r /app/requirements-test.txt
                '''
            }
        }

        // 🔥 UNIT TESTS
        stage('Unit Tests') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python -m pytest /app/tests/unit \
                    --maxfail=1 --disable-warnings
                '''
            }
        }

        // 🔥 SMOKE TESTS
        stage('Smoke Tests') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python -m pytest /app/tests/smoke
                '''
            }
        }

        // 🔥 INTEGRATION TESTS
        stage('Integration Tests') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python -m pytest /app/tests/integration \
                    --maxfail=1 --disable-warnings
                '''
            }
        }

        // 🔥 SETUP ADMIN
        stage('Setup Admin User') {
            steps {
                sh '''
                echo "Creating admin user..."
 
                docker exec -e PYTHONPATH=/app hms_auth python /app/create_admin.py || true

                echo "admin created successfully"
                '''
            }
        }


        // 🔥 REGRESSION TESTS
        stage('Regression Tests') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python -m pytest /app/tests/regression
                '''
            }
        }

        // 🔥 PERFORMANCE TEST (k6 via Docker)
        stage('Performance Tests') {
            steps {
                sh '''
                echo "Running performance tests (no mount) ..."

                ls $(pwd)/HEALIX_HMS/services/auth_service/tests/performance

                cat HEALIX_HMS/services/auth_service/tests/performance/load_test.js | docker run --rm -i \
                  --network=host \
                  grafana/k6 run -
                '''
            }
        }

        // 🔥 COVERAGE (IMPORTANT)
        stage('Generate Coverage') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python -m pytest /app/tests \
                    --cov=/app \
                    --cov-report=xml

                docker cp hms_auth:/app/coverage.xml .
                '''
            }
        }

        // 🔥 SONAR AFTER COVERAGE
        stage('SonarQube Analysis') {
            steps {
                dir('HEALIX_HMS') {
                    withSonarQubeEnv('sonarqube') {
                        script {
                            def scannerHome = tool 'sonar-scanner'
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose ps'
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh 'docker builder prune -f'
            }
        }
    }

    post {
        success {
            echo '✅ Deployment successful!'
        }
        failure {
            echo '❌ Deployment failed!'
        }
    }
}
