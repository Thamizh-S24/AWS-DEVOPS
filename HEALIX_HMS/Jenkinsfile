pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '0'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Stop Existing Containers') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose down || true'
                }
            }
        }

        stage('Build Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose build'
                }
            }
        }

        stage('Start Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose up -d'
                }
            }
        }

        // =========================
        // 🔥 WAIT FOR AUTH SERVICE
        // =========================
        stage('Wait for Services') {
            steps {
                sh '''
                echo "Waiting for auth service..."

                for i in $(seq 1 20); do
                  if docker exec hms_auth python -c "import requests; exit(0 if requests.get('http://localhost:8000/health').status_code==200 else 1)" >/dev/null 2>&1; then
                    echo "Auth Service UP ✅"
                    exit 0
                  fi
                  sleep 5
                done

                echo "Auth failed ❌"
                docker logs hms_auth
                exit 1
                '''
            }
        }

        // =========================
        // 🔥 INSTALL TEST DEPENDENCIES
        // =========================
        stage('Install Test Dependencies') {
            steps {
                sh '''
                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Installing test deps in $svc"
                    docker exec $svc python -m pip install -r /app/requirements-test.txt || true
                done
                '''
            }
        }

        // =========================
        // 🔥 UNIT TESTS
        // =========================
        stage('Unit Tests') {
            steps {
                sh '''
                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Running UNIT tests in $svc"
                    docker exec -e PYTHONPATH=/app $svc python -m pytest /app/tests -m unit || exit 1
                done
                '''
            }
        }

        // =========================
        // 🔥 SMOKE TESTS
        // =========================
        stage('Smoke Tests') {
            steps {
                sh '''
                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Running SMOKE tests in $svc"
                    docker exec -e PYTHONPATH=/app $svc python -m pytest /app/tests -m smoke || exit 1
                done
                '''
            }
        }

        // =========================
        // 🔥 INTEGRATION TESTS
        // =========================
        stage('Integration Tests') {
            steps {
                sh '''
                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Running INTEGRATION tests in $svc"
                    docker exec -e PYTHONPATH=/app $svc python -m pytest /app/tests -m integration || exit 1
                done
                '''
            }
        }

        stage('Setup Admin User') {
            steps {
                sh '''
                docker exec -e PYTHONPATH=/app hms_auth python /app/create_admin.py || true
                '''
            }
        }

        // =========================
        // 🔥 REGRESSION TESTS
        // =========================
        stage('Regression Tests') {
            steps {
                sh '''
                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Running REGRESSION tests in $svc"
                    docker exec -e PYTHONPATH=/app $svc python -m pytest /app/tests -m regression || exit 1
                done
                '''
            }
        }

        // =========================
        // 🔥 PERFORMANCE TEST
        // =========================
        stage('Performance Tests') {
            steps {
                sh '''
                cat HEALIX_HMS/services/auth_service/tests/performance/load_test.js | \
                docker run --rm -i --network=host grafana/k6 run -
                '''
            }
        }

        // =========================
        // 🔥 COVERAGE PER SERVICE
        // =========================
        stage('Generate Coverage') {
            steps {
                sh '''
                mkdir -p HEALIX_HMS/coverage

                for svc in $(docker ps --format '{{.Names}}' | grep hms_); do
                    echo "Generating coverage for $svc"

                    docker exec -e PYTHONPATH=/app $svc python -m pytest /app/tests \
                        --cov=app --cov-report=xml:/app/coverage.xml || true

                    docker cp $svc:/app/coverage.xml HEALIX_HMS/coverage/coverage-$svc.xml || true
                done
                '''
            }
        }

        // =========================
        // 🔥 MERGE COVERAGE
        // =========================
        stage('Merge Coverage') {
            steps {
                sh '''
                pip install coverage

                coverage combine HEALIX_HMS/coverage || true
                coverage xml -o HEALIX_HMS/coverage.xml
                '''
            }
        }

        // =========================
        // 🔥 SONAR
        // =========================
        stage('SonarQube Analysis') {
            steps {
                dir('HEALIX_HMS') {
                    withSonarQubeEnv('sonarqube') {
                        script {
                            def scannerHome = tool 'sonar-scanner'
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh 'docker builder prune -f'
            }
        }
    }

    post {
        success {
            echo '✅ Deployment successful!'
        }
        failure {
            echo '❌ Deployment failed!'
        }
    }
}
