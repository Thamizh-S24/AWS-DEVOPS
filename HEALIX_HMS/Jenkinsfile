pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '0'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Stop Existing Containers') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose down || true'
                }
            }
        }

        stage('Build Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose build'
                }
            }
        }

        stage('Start Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose up -d'
                }
            }
        }

        stage('Wait for Services') {
            steps {
                sh '''
                echo "Waiting for auth service..."

                for i in {1..20}; do
                  if docker exec hms_auth python -c "import requests; requests.get('http://localhost:8000/docs')" >/dev/null 2>&1; then
                    echo "Service is UP ✅"
                    exit 0
                  fi
                  echo "Waiting..."
                  sleep 3
                done

                echo "Service failed to start ❌"
                exit 1
                '''
            }
        }

        // 🔥 UNIT TESTS
        stage('Unit Tests') {
            steps {
                sh '''
                echo "Running unit tests..."

                docker exec hms_auth python -m pytest /app/tests/unit \
                    --maxfail=1 \
                    --disable-warnings
                '''
            }
        }

        // 🔥 SMOKE TESTS
        stage('Smoke Tests') {
            steps {
                sh '''
                echo "Running smoke tests..."

                docker exec hms_auth python -m pytest /app/tests/smoke
                '''
            }
        }

        // 🔥 INTEGRATION TESTS
        stage('Integration Tests') {
            steps {
                sh '''
                echo "Running integration tests..."

                docker exec hms_auth python -m pytest /app/tests/integration \
                    --maxfail=1 \
                    --disable-warnings
                '''
            }
        }

        // 🔥 REGRESSION TESTS
        stage('Regression Tests') {
            steps {
                sh '''
                echo "Running regression tests..."

                docker exec hms_auth python -m pytest /app/tests/regression
                '''
            }
        }

        // 🔥 PERFORMANCE TEST (k6 via Docker)
        stage('Performance Tests') {
            steps {
                sh '''
                echo "Running performance tests..."

                docker run --rm \
                  --network=host \
                  -v $(pwd)/HEALIX_HMS/services/auth_service/tests/performance:/scripts \
                  grafana/k6 run /scripts/load_test.js
                '''
            }
        }

        // 🔥 COVERAGE + FINAL TEST PASS
        stage('Generate Coverage') {
            steps {
                sh '''
                echo "Generating coverage report..."

                docker exec hms_auth python -m pytest /app/tests \
                    --cov=/app \
                    --cov-report=xml

                docker cp hms_auth:/app/coverage.xml .
                '''
            }
        }

        // 🔥 SONAR AFTER TESTS (IMPORTANT)
        stage('SonarQube Analysis') {
            steps {
                dir('HEALIX_HMS') {
                    withSonarQubeEnv('sonarqube') {
                        script {
                            def scannerHome = tool 'sonar-scanner'
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose ps'
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh 'docker builder prune -f'
            }
        }
    }

    post {
        success {
            echo '✅ Deployment successful!'
        }
        failure {
            echo '❌ Deployment failed!'
        }
    }
}
