pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '0'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('HEALIX_HMS') {
                    withSonarQubeEnv('sonarqube') {
                        script {
                            def scannerHome = tool 'sonar-scanner'
                            sh "${scannerHome}/bin/sonar-scanner"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Stop Existing Containers') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose down || true'
                }
            }
        }

        stage('Build Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose build'
                }
            }
        }

        stage('Start Services') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose up -d'
                }
            }
        }

        stage('Wait for Services') {
            steps {
                sh '''
                echo "Waiting for auth service..."

                for i in {1..20}; do
                  if docker exec hms_auth python -c "import requests; requests.get('http://localhost:8000/docs')" >/dev/null 2>&1; then
                    echo "Service is UP ✅"
                    exit 0
                  fi
                  echo "Waiting..."
                  sleep 3
                done

                echo "Service failed to start ❌"
                exit 1
                '''
            }
        }

        stage('Run Integration Tests') {
            steps {
                sh '''
                echo "Installing test dependencies..."

                docker exec hms_auth pip install -r /app/requirements.txt
                docker exec hms_auth pip install -r /app/requirements-test.txt

                echo "Running tests with coverage..."

                docker exec hms_auth python -m pytest /app/tests \
                    --maxfail=1 \
                    --disable-warnings \
                    --cov=/app \
                    --cov-report=xml
                
                echo "Copying coverage report to Jenkins workspace..."

                docker cp hms_auth:/app/coverage.xml
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                dir('HEALIX_HMS') {
                    sh 'docker-compose ps'
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh 'docker builder prune -f'
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}
