# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
ENVIRONMENT=development

# Gateway Configuration
GATEWAY_PORT=8000

# Service Database URLs
# Format: mongodb://[username:password@]host:port/database_name
AUTH_DB_URL=mongodb://mongo:27017/hms_auth
PATIENT_DB_URL=mongodb://mongo:27017/hms_patient
DOCTOR_DB_URL=mongodb://mongo:27017/hms_doctor
WARD_DB_URL=mongodb://mongo:27017/hms_ward
EMERGENCY_DB_URL=mongodb://mongo:27017/hms_emergency
PHARMACY_DB_URL=mongodb://mongo:27017/hms_pharmacy
ANALYTICS_DB_URL=mongodb://mongo:27017/hms_analytics

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api

# SMTP Configuration (For Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
